{
  "$schema": "http://json.schemastore.org/template",
  "author": "Your Name",
  "classifications": [ "Web", "API", "SaaS", "Backend" ],
  "identity": "SaasStarter.Template.CSharp",
  "name": "SaaS Starter API",
  "description": "Backend .NET 10 com JWT, Google OAuth, Stripe (cartão, boleto, PIX), planos e promoções.",
  "shortName": "saas-starter",
  "sourceName": "SaasStarter",
  "preferNameDirectory": true,
  "tags": {
    "language": "C#",
    "type": "solution"
  },
  "symbols": {
    "appDisplayName": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "",
      "description": "Nome de exibição do app (e-mails, docs). Deixe vazio para usar o nome do projeto.",
      "replaces": "SaasStarter"
    }
  },
  "sources": [
    {
      "exclude": [
        ".template.config/**",
        "SaasStarter.Template.csproj",
        "install.ps1",
        "install.sh",
        "**/*.nupkg",
        "**/bin/**",
        "**/obj/**"
      ]
    }
  ]
}
