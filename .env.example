# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=saas_starter
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Mínimo 32 caracteres — gere com: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars
JWT_ISSUER=SaasStarter
JWT_AUDIENCE=SaasStarter
JWT_EXPIRATION_HOURS=24

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_BASE_URL=https://app.seudominio.com.br

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Crie em console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── Resend (e-mail transacional) ──────────────────────────────────────────────
# Crie em resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_ADDRESS=noreply@seudominio.com.br

# ── Stripe ────────────────────────────────────────────────────────────────────
# Crie em dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
# Crie em dashboard.stripe.com → Developers → Webhooks → Add endpoint
# URL: https://api.seudominio.com.br/api/payments/webhook
# Eventos: checkout.session.completed, checkout.session.async_payment_succeeded, checkout.session.async_payment_failed
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
